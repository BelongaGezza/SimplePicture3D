{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SimplePicture3D",
  "version": "0.1.0",
  "identifier": "com.simplepicture3d.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "assetProtocol": {
        "enable": false
      },
      "csp": "default-src 'self'; img-src 'self' blob: data:"
    },
    "windows": [
      {
        "title": "SimplePicture3D",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "Convert 2D images into 3D surface point clouds (PLY/XYZ/CSV) for internal UV laser engraving of K9 crystal, glass, and acrylic blanks. 100% offline.",
    "shortDescription": "2D image to 3D surface point cloud for crystal laser engraving",
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "Graphics"
  },
  "plugins": {}
}